# Server
HOST=0.0.0.0
PORT=8080

# Blockchain
CHAIN_ID=1
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# The deployed MinimalForwarder contract
FORWARDER_ADDRESS=0xYOUR_FORWARDER_ADDRESS

# EIP-712 domain name
DOMAIN_NAME=MyDAppRelayer

# Relayer Wallet
# For Railway/Production: Set this as a secret environment variable
RELAYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Database (Neon/Postgres)
DATABASE_URL=postgresql://user:password@your-neon-hostname.neon.tech/main

# Redis
REDIS_URL=redis://localhost:6379

# Logging
RUST_LOG=gas_relayer=debug,tower_http=info
