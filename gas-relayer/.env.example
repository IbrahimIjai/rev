# Server
HOST=0.0.0.0
PORT=8080

# Blockchain
CHAIN_ID=1
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# OZ ERC2771Forwarder address — deployed once per chain
FORWARDER_ADDRESS=0xYOUR_FORWARDER_ADDRESS

# EIP-712 domain name (must match what was passed to ERC2771Forwarder constructor)
DOMAIN_NAME=GasRelayForwarder

# Relayer hot wallet — funds used for gas, NOT user funds
RELAYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Neon DB (PostgreSQL-compatible serverless)
# Format: postgresql://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# Auth — random high-entropy secret for JWT signing
JWT_SECRET=change-me-at-least-32-chars-random

# Encryption — AES-256-GCM key for relayer private key storage (32 bytes when decoded)
ENCRYPTION_SECRET=change-me-at-least-32-chars-random

# Logging
RUST_LOG=gas_relayer=debug,tower_http=info
